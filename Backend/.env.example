# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/resume_genai

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_GENAI_API_KEY=replace-with-your-google-genai-api-key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
# For production, use the site origin only, with no path:
# CLIENT_URL=https://your-vercel-app.vercel.app
# Optional comma-separated list for multiple deployed frontend origins:
# CLIENT_URLS=https://your-vercel-app.vercel.app,https://your-preview.vercel.app
